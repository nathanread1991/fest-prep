[flake8]
# Flake8 configuration for Festival Playlist Generator

# Maximum line length (match Black's default)
max-line-length = 88

# Maximum cyclomatic complexity
max-complexity = 10

# Exclude directories
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    env,
    .eggs,
    *.egg,
    build,
    dist,
    .pytest_cache,
    .mypy_cache,
    htmlcov,
    alembic/versions,
    node_modules

# Ignore specific error codes
ignore =
    # E203: whitespace before ':' (conflicts with Black)
    E203,
    # E501: line too long (handled by Black)
    E501,
    # W503: line break before binary operator (conflicts with Black)
    W503,
    # E402: module level import not at top of file
    E402

# Select error codes to check
select = E,W,F,C

# Show source code for each error
show-source = True

# Show statistics
statistics = True

# Count errors
count = True
